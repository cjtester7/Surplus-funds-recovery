rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Eligibility Requests
    match /eligibility_requests/{requestId} {
      // Anyone can submit a request (create), but they must follow the schema
      allow create: if isValidEligibilityRequest(request.resource.data);
      
      // Only admins can read or manage these requests
      allow read, list, update, delete: if isAdmin();
    }
    
    // Admin check: assumes an 'admins' collection where doc ID is the user ID
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEligibilityRequest(data) {
      return data.keys().hasAll(['address', 'state', 'auctionDate', 'phone', 'email', 'createdAt'])
        && data.keys().size() == 6
        && data.address is string && data.address.size() <= 500
        && data.state is string && data.state.size() <= 100
        && data.auctionDate is string && data.auctionDate.size() <= 100
        && data.phone is string && data.phone.size() <= 50
        && data.email is string && data.email.size() <= 200
        && data.createdAt == request.time;
    }
  }
}
