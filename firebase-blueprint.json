{
  "entities": {
    "EligibilityRequest": {
      "title": "Eligibility Request",
      "description": "Information provided by a homeowner seeking surplus funds recovery.",
      "type": "object",
      "properties": {
        "address": { "type": "string", "description": "Property address" },
        "state": { "type": "string", "description": "State where the foreclosure occurred" },
        "auctionDate": { "type": "string", "description": "Approximate date of the auction" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "email": { "type": "string", "description": "Contact email address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server-side timestamp of creation" }
      },
      "required": ["address", "state", "auctionDate", "phone", "email", "createdAt"]
    }
  },
  "firestore": {
    "eligibility_requests/{requestId}": {
      "schema": "EligibilityRequest",
      "description": "Collection of incoming leads for surplus recovery reviews."
    }
  }
}
